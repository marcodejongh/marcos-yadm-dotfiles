#!/usr/bin/env bash
set -euo pipefail

tmux_bin="${TMUX_BIN:-tmux}"

touch_pane() {
  local target="${1:-}"
  local current next

  if [[ -z "$target" ]]; then
    exit 0
  fi

  "$tmux_bin" wait-for -L pane-switcher-recency
  trap '"$tmux_bin" wait-for -U pane-switcher-recency' EXIT

  current="$("$tmux_bin" show-option -gqv @pane_switcher_seq 2>/dev/null || true)"
  if [[ ! "$current" =~ ^[0-9]+$ ]]; then
    current=0
  fi

  next=$((current + 1))
  "$tmux_bin" set-option -gq @pane_switcher_seq "$next"
  "$tmux_bin" set-option -pqt "$target" @pane_switcher_last_used "$next" 2>/dev/null || true
}

case "${1:-}" in
  --touch)
    touch_pane "${2:-}"
    exit 0
    ;;
esac

if ! command -v fzf >/dev/null 2>&1; then
  "$tmux_bin" display-message "fzf not found"
  exit 1
fi

current_pane="$("$tmux_bin" display-message -p '#{pane_id}' 2>/dev/null || true)"

selection="$(
  "$tmux_bin" list-panes -aF '#{session_name}	#{window_index}	#{pane_index}	#{window_bell_flag}	#{window_activity_flag}	#{window_name}	#{pane_current_command}	#{pane_current_path}	#{@agent_title}	#{pane_title}	#{pane_id}	#{@pane_switcher_last_used}' |
    awk -F '\t' -v current_pane="$current_pane" '
      function clean(value) {
        gsub(/\r/, "", value)
        gsub(/\t/, " ", value)
        gsub(/^[[:space:]]+/, "", value)
        gsub(/[[:space:]]+$/, "", value)
        return value
      }

      function shorten(value, max) {
        value = clean(value)
        if (length(value) <= max) {
          return value
        }
        return substr(value, 1, max - 3) "..."
      }

      function basename(path, parts, n) {
        path = clean(path)
        if (path == ENVIRON["HOME"]) {
          return "~"
        }
        sub(/\/+$/, "", path)
        n = split(path, parts, "/")
        if (n == 0 || parts[n] == "") {
          return path
        }
        return parts[n]
      }

      function best_title(agent, pane, window, command) {
        agent = clean(agent)
        pane = clean(pane)
        window = clean(window)
        command = clean(command)

        if (agent != "") {
          return agent
        }
        if (pane != "" && pane != window) {
          return pane
        }
        if (window != "") {
          return window
        }
        return command
      }

      {
        session = clean($1)
        window_index = $2 + 0
        pane_index = $3 + 0
        bell = $4 + 0
        activity = $5 + 0
        window = clean($6)
        command = clean($7)
        cwd = clean($8)
        agent = clean($9)
        pane = clean($10)
        pane_id = clean($11)
        last_used = clean($12) + 0

        title = best_title(agent, pane, window, command)
        repo = basename(cwd)
        target = session ":" window_index "." pane_index
        combined = tolower(agent " " pane " " window " " command)
        current_rank = (pane_id == current_pane) ? 1 : 0

        if (combined ~ /action required|needs action|blocked|failed|error/ || bell) {
          priority = 0
          marker = "[!]"
        } else if (activity) {
          priority = 1
          marker = "[+]"
        } else if (combined ~ /working|running|continuing|in progress/) {
          priority = 2
          marker = "[>]"
        } else {
          priority = 9
          marker = "[ ]"
        }

        row = sprintf("%s %-56s  %-24s  %-14s  %s", marker, shorten(title, 56), shorten(repo, 24), shorten(command, 14), target)

        print current_rank "\t" priority "\t" last_used "\t" session "\t" window_index "\t" pane_index "\t" target "\t" row
      }
    ' |
    sort -t $'\t' -k1,1n -k2,2n -k3,3nr -k4,4 -k5,5n -k6,6n |
    fzf --delimiter=$'\t' \
      --with-nth=8.. \
      --no-sort \
      --reverse \
      --cycle \
      --prompt='pane> ' \
      --header='Enter: switch  Esc: cancel  attention first, newest within each group'
)"

if [[ -z "${selection:-}" ]]; then
  exit 0
fi

target="$(awk -F '\t' '{print $7}' <<<"$selection")"

if [[ -n "$target" ]]; then
  exec "$tmux_bin" switch-client -t "$target"
fi
