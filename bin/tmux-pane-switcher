#!/usr/bin/env bash
set -euo pipefail

tmux_bin="${TMUX_BIN:-tmux}"
pr_cache_bin="${TMUX_PR_CACHE_BIN:-$HOME/bin/tmux-pr-cache}"
tmp_files=()

cleanup() {
  rm -f "${tmp_files[@]}" 2>/dev/null || true
}

touch_pane() {
  local target="${1:-}"
  local current next

  if [[ -z "$target" ]]; then
    exit 0
  fi

  "$tmux_bin" wait-for -L pane-switcher-recency
  trap '"$tmux_bin" wait-for -U pane-switcher-recency' EXIT

  current="$("$tmux_bin" show-option -gqv @pane_switcher_seq 2>/dev/null || true)"
  if [[ ! "$current" =~ ^[0-9]+$ ]]; then
    current=0
  fi

  next=$((current + 1))
  "$tmux_bin" set-option -gq @pane_switcher_seq "$next"
  "$tmux_bin" set-option -pqt "$target" @pane_switcher_last_used "$next" 2>/dev/null || true
}

case "${1:-}" in
  --touch)
    touch_pane "${2:-}"
    exit 0
    ;;
esac

if ! command -v fzf >/dev/null 2>&1; then
  "$tmux_bin" display-message "fzf not found"
  exit 1
fi

trap cleanup EXIT

panes_file="$(mktemp "${TMPDIR:-/tmp}/tmux-pane-switcher-panes.XXXXXX")"
worktree_cache_file="$(mktemp "${TMPDIR:-/tmp}/tmux-pane-switcher-worktrees.XXXXXX")"
tmp_files+=("$panes_file" "$worktree_cache_file")

current_pane="$("$tmux_bin" display-message -p '#{pane_id}' 2>/dev/null || true)"
menu_width="$("$tmux_bin" display-message -p '#{client_width}' 2>/dev/null || true)"
if [[ ! "$menu_width" =~ ^[0-9]+$ ]]; then
  menu_width=120
fi

"$tmux_bin" list-panes -aF '#{session_name}	#{window_index}	#{pane_index}	#{window_bell_flag}	#{window_activity_flag}	#{window_name}	#{pane_current_command}	#{pane_current_path}	#{@agent_title}	#{pane_title}	#{pane_id}	#{@pane_switcher_last_used}' >"$panes_file"
if [[ -x "$pr_cache_bin" ]]; then
  "$pr_cache_bin" read-cache >"$worktree_cache_file" 2>/dev/null || true
elif command -v tmux-pr-cache >/dev/null 2>&1; then
  tmux-pr-cache read-cache >"$worktree_cache_file" 2>/dev/null || true
fi

selection="$(
  awk -F '\t' -v current_pane="$current_pane" -v menu_width="$menu_width" -v worktree_cache_file="$worktree_cache_file" '
      BEGIN {
        title_width = 56
        context_width = 28

        while ((getline line < worktree_cache_file) > 0) {
          split(line, parts, "\t")
          if (parts[1] == "" || parts[2] == "") {
            continue
          }
          cache_count++
          cache_root[cache_count] = clean(parts[1])
          cache_branch[cache_count] = clean(parts[2])
          cache_pr[cache_count] = clean(parts[3])
        }
        close(worktree_cache_file)
      }

      function clean(value) {
        gsub(/\r/, "", value)
        gsub(/\t/, " ", value)
        gsub(/^[[:space:]]+/, "", value)
        gsub(/[[:space:]]+$/, "", value)
        return value
      }

      function shorten(value, max) {
        value = clean(value)
        if (max <= 0) {
          return ""
        }
        if (max <= 3 && length(value) > max) {
          return substr(value, 1, max)
        }
        if (length(value) <= max) {
          return value
        }
        return substr(value, 1, max - 3) "..."
      }

      function root_matches(cwd, root) {
        return cwd == root || index(cwd, root "/") == 1
      }

      function best_cache_index(cwd,    i, best, best_len) {
        best = 0
        best_len = 0
        for (i = 1; i <= cache_count; i++) {
          if (root_matches(cwd, cache_root[i]) && length(cache_root[i]) > best_len) {
            best = i
            best_len = length(cache_root[i])
          }
        }
        return best
      }

      function pad(value, width) {
        value = shorten(value, width)
        return sprintf("%-" width "s", value)
      }

      function basename(path, parts, n) {
        path = clean(path)
        if (path == ENVIRON["HOME"]) {
          return "~"
        }
        sub(/\/+$/, "", path)
        n = split(path, parts, "/")
        if (n == 0 || parts[n] == "") {
          return path
        }
        return parts[n]
      }

      function best_title(agent, pane, window, command) {
        agent = clean(agent)
        pane = clean(pane)
        window = clean(window)
        command = clean(command)

        if (agent != "") {
          return agent
        }
        if (pane != "" && pane != window) {
          return pane
        }
        if (window != "") {
          return window
        }
        return command
      }

      {
        session = clean($1)
        window_index = $2 + 0
        pane_index = $3 + 0
        bell = $4 + 0
        activity = $5 + 0
        window = clean($6)
        command = clean($7)
        cwd = clean($8)
        agent = clean($9)
        pane = clean($10)
        pane_id = clean($11)
        last_used = clean($12) + 0

        title = best_title(agent, pane, window, command)
        cache_index = best_cache_index(cwd)
        if (cache_index > 0) {
          pane_context = cache_branch[cache_index]
          pr_text = cache_pr[cache_index]
        } else {
          pane_context = basename(cwd)
          pr_text = ""
        }
        target = session ":" window_index "." pane_index
        combined = tolower(agent " " pane " " window " " command)
        current_rank = (pane_id == current_pane) ? 1 : 0

        if (combined ~ /action required|needs action|blocked|failed|error/ || bell) {
          priority = 0
          marker = "[!]"
        } else if (activity) {
          priority = 1
          marker = "[+]"
        } else if (combined ~ /working|running|continuing|in progress/) {
          priority = 2
          marker = "[>]"
        } else {
          priority = 9
          marker = "[ ]"
        }

        detail_width = menu_width - length(marker) - 2 - title_width - 3 - context_width - 3 - 3 - length(target)
        if (detail_width < 0) {
          detail_width = 0
        } else if (detail_width > 80) {
          detail_width = 80
        }

        row = marker "  " pad(title, title_width) " | " pad(pane_context, context_width) " | " pad(pr_text, detail_width) " | " target

        print current_rank "\t" priority "\t" last_used "\t" session "\t" window_index "\t" pane_index "\t" target "\t" row
      }
    ' "$panes_file" |
    sort -t $'\t' -k1,1n -k2,2n -k3,3nr -k4,4 -k5,5n -k6,6n |
    fzf --delimiter=$'\t' \
      --with-nth=8.. \
      --no-sort \
      --reverse \
      --cycle \
      --prompt='pane> ' \
      --header=$'Enter: switch  Esc: cancel  attention first, newest within each group\nstate  title                                                    | branch/worktree              | pull request | target'
)"

if [[ -z "${selection:-}" ]]; then
  exit 0
fi

target="$(awk -F '\t' '{print $7}' <<<"$selection")"

if [[ -n "$target" ]]; then
  exec "$tmux_bin" switch-client -t "$target"
fi
