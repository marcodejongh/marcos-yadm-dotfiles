#!/usr/bin/env bash
set -euo pipefail

tmux_bin="${TMUX_BIN:-tmux}"

if ! command -v fzf >/dev/null 2>&1; then
  "$tmux_bin" display-message "fzf not found"
  exit 1
fi

selection="$(
  "$tmux_bin" list-panes -aF '#{session_name}	#{window_index}	#{pane_index}	#{window_bell_flag}	#{window_activity_flag}	#{window_name}	#{pane_current_command}	#{pane_current_path}	#{@agent_title}	#{pane_title}' |
    awk -F '\t' '
      function clean(value) {
        gsub(/\r/, "", value)
        gsub(/\t/, " ", value)
        gsub(/^[[:space:]]+/, "", value)
        gsub(/[[:space:]]+$/, "", value)
        return value
      }

      function shorten(value, max) {
        value = clean(value)
        if (length(value) <= max) {
          return value
        }
        return substr(value, 1, max - 3) "..."
      }

      function basename(path, parts, n) {
        path = clean(path)
        if (path == ENVIRON["HOME"]) {
          return "~"
        }
        sub(/\/+$/, "", path)
        n = split(path, parts, "/")
        if (n == 0 || parts[n] == "") {
          return path
        }
        return parts[n]
      }

      function best_title(agent, pane, window, command) {
        agent = clean(agent)
        pane = clean(pane)
        window = clean(window)
        command = clean(command)

        if (agent != "") {
          return agent
        }
        if (pane != "" && pane != window) {
          return pane
        }
        if (window != "") {
          return window
        }
        return command
      }

      {
        session = clean($1)
        window_index = $2 + 0
        pane_index = $3 + 0
        bell = $4 + 0
        activity = $5 + 0
        window = clean($6)
        command = clean($7)
        cwd = clean($8)
        agent = clean($9)
        pane = clean($10)

        title = best_title(agent, pane, window, command)
        repo = basename(cwd)
        target = session ":" window_index "." pane_index
        combined = tolower(agent " " pane " " window " " command)

        if (combined ~ /action required|needs action|blocked|failed|error/ || bell) {
          priority = 0
          marker = "[!]"
        } else if (activity) {
          priority = 1
          marker = "[+]"
        } else if (combined ~ /working|running|continuing|in progress/) {
          priority = 2
          marker = "[>]"
        } else {
          priority = 9
          marker = "[ ]"
        }

        sort_key = sprintf("%02d|%s|%05d|%05d", priority, session, window_index, pane_index)
        row = sprintf("%s %-56s  %-24s  %-14s  %s", marker, shorten(title, 56), shorten(repo, 24), shorten(command, 14), target)

        print sort_key "\t" target "\t" row
      }
    ' |
    sort -t $'\t' -k1,1 |
    fzf --delimiter=$'\t' \
      --with-nth=3.. \
      --no-sort \
      --reverse \
      --cycle \
      --prompt='pane> ' \
      --header='Enter: switch  Esc: cancel  [!]=action/alert  [+]=activity  [>]=working'
)"

if [[ -z "${selection:-}" ]]; then
  exit 0
fi

target="$(awk -F '\t' '{print $2}' <<<"$selection")"

if [[ -n "$target" ]]; then
  exec "$tmux_bin" switch-client -t "$target"
fi
