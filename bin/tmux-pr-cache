#!/usr/bin/env bash
set -euo pipefail

cache_dir="${TMUX_PR_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/tmux-pane-switcher/worktrees}"
cache_ttl="${TMUX_PR_CACHE_TTL:-300}"
lock_dir=""

if [[ ! "$cache_ttl" =~ ^[0-9]+$ ]]; then
  cache_ttl=300
fi

hash_text() {
  if command -v shasum >/dev/null 2>&1; then
    shasum | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}'
  else
    cksum | awk '{print $1 "-" $2}'
  fi
}

normalize_pr_text() {
  tr '\r\n\t' '   ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

cache_file_for_root() {
  local root="$1"
  local key

  key="$(printf "%s" "$root" | hash_text)"
  printf "%s/%s\n" "$cache_dir" "$key"
}

cache_field() {
  local field="$1"
  local cache_file="$2"

  awk -F '\t' -v field="$field" '
    $1 == field {
      print substr($0, length($1) + 2)
      found = 1
      exit
    }
    END {
      exit found ? 0 : 1
    }
  ' "$cache_file"
}

resolve_worktree() {
  local cwd="$1"
  local root branch

  [[ -n "$cwd" && -d "$cwd" ]] || return 1
  command -v git >/dev/null 2>&1 || return 1

  root="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null)" || return 1
  branch="$(git -C "$cwd" symbolic-ref --quiet --short HEAD 2>/dev/null)" || return 1
  [[ -n "$root" && -n "$branch" ]] || return 1

  printf "%s\t%s\n" "$root" "$branch"
}

cache_is_fresh_for_branch() {
  local cache_file="$1"
  local branch="$2"
  local cached_at cached_branch now

  [[ "$cache_ttl" -gt 0 && -r "$cache_file" ]] || return 1

  cached_branch="$(cache_field branch "$cache_file" 2>/dev/null || true)"
  [[ "$cached_branch" == "$branch" ]] || return 1

  cached_at="$(cache_field updated_at "$cache_file" 2>/dev/null || true)"
  [[ "$cached_at" =~ ^[0-9]+$ ]] || return 1

  now="$(date +%s)"
  [[ "$now" =~ ^[0-9]+$ ]] || return 1
  ((now - cached_at <= cache_ttl))
}

query_pr_text() {
  local root="$1"
  local branch="$2"

  command -v gh >/dev/null 2>&1 || return 0

  cd "$root" 2>/dev/null && \
    GH_PROMPT_DISABLED=1 gh pr list \
      --head "$branch" \
      --state open \
      --json number,title \
      --limit 1 \
      --jq 'if length == 0 then "" else "#\(.[0].number) \(.[0].title)" end' \
      2>/dev/null | normalize_pr_text || true
}

write_cache() {
  local cache_file="$1"
  local root="$2"
  local branch="$3"
  local pr_text="$4"
  local tmp_file

  mkdir -p "$cache_dir"
  tmp_file="$cache_file.tmp.$$"

  {
    printf "updated_at\t%s\n" "$(date +%s)"
    printf "root\t%s\n" "$root"
    printf "branch\t%s\n" "$branch"
    printf "pr\t%s\n" "$pr_text"
  } >"$tmp_file"

  mv "$tmp_file" "$cache_file"
}

refresh_path() {
  local cwd="$1"
  local root branch info cache_file pr_text

  info="$(resolve_worktree "$cwd")" || return 0
  IFS=$'\t' read -r root branch <<<"$info"

  mkdir -p "$cache_dir"
  cache_file="$(cache_file_for_root "$root")"
  cache_is_fresh_for_branch "$cache_file" "$branch" && return 0

  lock_dir="$cache_file.lock"
  mkdir "$lock_dir" 2>/dev/null || return 0
  trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT

  cache_is_fresh_for_branch "$cache_file" "$branch" && return 0
  pr_text="$(query_pr_text "$root" "$branch")"
  write_cache "$cache_file" "$root" "$branch" "$pr_text"
}

spawn_refresh_path() {
  local cwd="$1"

  if command -v nohup >/dev/null 2>&1; then
    (nohup "$0" refresh-path "$cwd" </dev/null >/dev/null 2>&1 &)
  else
    ("$0" refresh-path "$cwd" </dev/null >/dev/null 2>&1 &)
  fi
}

warm_tmux() {
  local tmux_bin="${TMUX_BIN:-tmux}"

  command -v "$tmux_bin" >/dev/null 2>&1 || return 0
  "$tmux_bin" list-panes -aF '#{pane_current_path}' 2>/dev/null |
    awk 'NF && !seen[$0]++' |
    while IFS= read -r cwd; do
      spawn_refresh_path "$cwd"
    done
}

read_cache() {
  local cache_file root branch pr_text

  [[ -d "$cache_dir" ]] || return 0

  for cache_file in "$cache_dir"/*; do
    [[ -f "$cache_file" ]] || continue

    root="$(cache_field root "$cache_file" 2>/dev/null || true)"
    branch="$(cache_field branch "$cache_file" 2>/dev/null || true)"
    pr_text="$(cache_field pr "$cache_file" 2>/dev/null || true)"
    [[ -n "$root" && -n "$branch" ]] || continue

    printf "%s\t%s\t%s\n" "$root" "$branch" "$pr_text"
  done
}

usage() {
  cat <<'USAGE'
usage: tmux-pr-cache <command> [args]

commands:
  refresh-path <cwd>  Refresh the cached branch and PR metadata for a path
  warm-tmux           Refresh cache entries for all current tmux pane paths
  read-cache          Print cached worktree rows as root<TAB>branch<TAB>pr
USAGE
}

case "${1:-}" in
  refresh-path)
    refresh_path "${2:-}"
    ;;
  warm-tmux)
    warm_tmux
    ;;
  read-cache)
    read_cache
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
