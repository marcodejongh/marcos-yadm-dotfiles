[window]
option_as_alt = "Both"

[font.normal]
family = "MesloLGS NF"

[hints]
alphabet = "jfkdls;ahgurieowpq"

[[keyboard.bindings]]
key = "W"
mods = "Alt"
chars = "\u001bw"

# Plain http(s) links (replaces Alacritty's built-in default URL hint, which
# defining [hints] otherwise removes)
[[hints.enabled]]
regex = 'https?://[^\s<>"(){}\[\]]+'
hyperlinks = true
post_processing = true
command = "open"
mouse = { enabled = true, mods = "Command" }
binding = { key = "U", mods = "Control|Shift" }
